{
  "manifest_version": 3,
  "name": "Querryn",
  "version": "1.0.0",
  "description": "Querryn scans pages for sources and rates their credibility to help students cite better.",
  "permissions": ["activeTab", "storage", "scripting"],
  "icons": {
    "16":  "assets/icon16.png",
    "32":  "assets/icon32.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Querryn",
    "default_icon": {
      "16":  "assets/icon16.png",
      "32":  "assets/icon32.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["domainLists.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
